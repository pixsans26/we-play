{
  "expo": {
    "name": "WePlay",
    "slug": "couples-scratch-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "couples-scratch-game",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ff2d6b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.couples.scratchgame"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ff2d6b"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.couples.scratchgame"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
